# ────────────────────────────────────────────────────────────────────────────
# NovaPrintLab — Environment Variables
# Bu dosyayı .env.local olarak kopyala ve sadece kullanmak istediğin
# motorların key'lerini doldur. Boş kalan motorlar UI'da seçildiğinde
# kullanıcıya "API key tanımlı değil" hatası gösterir.
# ────────────────────────────────────────────────────────────────────────────

# ─── OpenAI (gpt-image-1 + AI tasarım + SEO) ────────────────────────────────
# Mevcut motor. Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Supabase (veritabanı + storage) ────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Mockup engine alternatifleri ───────────────────────────────────────────
# Sadece kullanacağın motorun key'ini doldur, gerisi opsiyonel.

# ─── Replicate FLUX Dev img2img — ~$0.012 / mockup ──────────────────────────
# 1 dk kayıt, $10 ücretsiz başlangıç kredisi.
# Get key: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ─── fal.ai FLUX Dev img2img — ~$0.025-0.05 / mockup ────────────────────────
# En hızlı motor (~2-3 saniye). $1 ücretsiz başlangıç kredisi.
# Get key: https://fal.ai/dashboard/keys
FAL_API_KEY=

# ─── Google Gemini 2.5 Flash Image — TAMAMEN ÜCRETSİZ ───────────────────────
# Free tier: ~100 mockup/gün. Beta, kalite değişken olabilir.
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Recraft v3 img2img — ~25 ücretsiz/gün, sonrasında $0.04 / mockup ───────
# Mockup için özel eğitilmiş model. Image-to-image API destekler.
# Get key: https://www.recraft.ai/profile/api
RECRAFT_API_TOKEN=
