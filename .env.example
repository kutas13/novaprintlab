OPENAI_API_KEY=your-openai-api-key-here

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: service role lets API routes bypass RLS for orders sync/webhook.
# If omitted, the routes fall back to the anon key (works because our RLS is open).
SUPABASE_SERVICE_ROLE_KEY=

# Etsy API v3 — required by /api/etsy/sync and listing-image lookups
# Create app at: https://www.etsy.com/developers/your-apps
ETSY_API_KEY=
ETSY_SHOP_ID=
ETSY_ACCESS_TOKEN=

# Optional: shared secret for /api/etsy/webhook. When set, the endpoint
# requires header `x-webhook-secret: <value>` on every POST.
ETSY_WEBHOOK_SECRET=
