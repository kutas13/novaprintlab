# ============================================================
#  REQUIRED — Core
# ============================================================

# OpenAI key (Kerim'in AI SEO için)
OPENAI_API_KEY=

# Supabase project — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — Settings → API → service_role (SECRET)
# Etsy OAuth token storage'ı bunu kullanır. Vercel'de mutlaka ekle.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
#  REQUIRED — Etsy
# ============================================================

# Etsy Developer App keystring
# https://www.etsy.com/developers/your-apps  →  Create App  →  keystring
ETSY_API_KEY=

# ============================================================
#  OPTIONAL — Etsy
# ============================================================

# Eğer OAuth UI'yi kullanmak istemiyorsan (önerilmez — token saatlik dolar)
# bu üçünü doldurabilirsin. UI'de "Etsy ile Bağlan" basarsan bunlara gerek yok.
ETSY_SHOP_ID=
ETSY_ACCESS_TOKEN=

# /api/etsy/webhook için paylaşılan secret. Set edersen her POST için
# `x-webhook-secret: <value>` header'ı zorunlu olur. Boş bırakırsan webhook
# açık olur (yine de URL gizli kalır).
ETSY_WEBHOOK_SECRET=
